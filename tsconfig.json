{
  "extends": "./.config/tsconfig.json",
  "compilerOptions": {
    "rootDir": ".",
    "baseUrl": "src",
    "removeComments": true,
    "noUnusedLocals": false,
    "noUnusedParameters": false,
    "noImplicitAny": false,
    "strictNullChecks": true,
    "paths": {
      "~/*": ["../mapLib/src/*"]
    }
  },
  "include": ["src", "mapLib/src", ".config/types"]
}
