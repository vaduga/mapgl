    "typecheck:native": "tsgo --noEmit -p tsconfig.native.json",
    "check:private-imports": "node scripts/check-private-imports.mjs",
    "lint": "eslint --cache .",
    "lint:fix": "npm run lint -- --fix && prettier --write --list-different .",
    "e2e": "playwright test",
    "server": "docker compose up --build",
    "sign": "sign-plugin"
  },
